{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "kild",
  "version": "0.0.1",
  "identifier": "com.rasmus.kild",
  "build": {
    "beforeDevCommand": "bun run dev:full",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build:all",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "kild",
        "width": 1100,
        "height": 760,
        "titleBarStyle": "Transparent",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": ["binaries/kild-engine"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
