{
  "name": "kild-engine",
  "private": true,
  "type": "module",
  "version": "0.0.1",
  "description": "kild engine — the agent runtime, daemon, and CLI. Coding-agent SDK substrate, Flue as a layer.",
  "bin": {
    "kild": "./src/cli.ts"
  },
  "scripts": {
    "dev": "bun run --watch src/server.ts",
    "serve": "bun run src/server.ts",
    "cli": "bun run src/cli.ts",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src",
    "format": "biome format --write src",
    "flue": "flue"
  },
  "dependencies": {
    "@earendil-works/pi-agent-core": "*",
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "^0.78.1",
    "@flue/runtime": "^0.9.2",
    "hono": "^4.8.3",
    "just-bash": "^3.0.1",
    "valibot": "^1.1.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.0",
    "@flue/cli": "^0.9.2",
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0"
  }
}
